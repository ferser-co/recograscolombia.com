---
import type { ServiciosData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;
---

<a
  id="floating-cta"
  href={data.contact.whatsappLink}
  target="_blank"
  rel="noopener"
  aria-label="Solicitar recolección por WhatsApp"
  class="floating-cta group fixed bottom-5 right-5 z-50 inline-flex h-14 items-center overflow-hidden rounded-full bg-brand-600 text-white shadow-xl shadow-brand-900/25 ring-1 ring-black/5 opacity-0 pointer-events-none"
>
  <span class="grid h-14 w-14 shrink-0 place-items-center">
    <Icon name="message-circle" class="w-6 h-6" />
  </span>
  <span class="fab-text font-semibold">Solicitar recolección</span>
</a>

<script is:inline>
  (function () {
    var fab = document.getElementById('floating-cta');
    var anchor = document.getElementById('hero-cta');
    if (!fab) return;
    var flown = false;
    var collapseTimer;

    function reveal() {
      fab.classList.remove('opacity-0', 'pointer-events-none');
      if (flown) return;
      flown = true;
      if (anchor) {
        var f = fab.getBoundingClientRect();
        var h = anchor.getBoundingClientRect();
        var dx = h.left + h.width / 2 - (f.left + f.width / 2);
        var dy = h.top + h.height / 2 - (f.top + f.height / 2);
        fab.style.transition = 'none';
        fab.style.transform = 'translate(' + dx + 'px,' + dy + 'px) scale(0.85)';
        void fab.offsetWidth;
        requestAnimationFrame(function () {
          fab.style.transition = '';
          fab.style.transform = 'translate(0,0) scale(1)';
        });
      }
      // Llega expandido (muestra el texto), luego se colapsa a solo ícono
      setTimeout(function () {
        fab.style.transform = '';
        fab.classList.add('fab-open');
        collapseTimer = setTimeout(function () {
          fab.classList.remove('fab-open');
        }, 2600);
      }, anchor ? 620 : 0);
    }

    function hide() {
      fab.classList.add('opacity-0', 'pointer-events-none');
      fab.classList.remove('fab-open');
      clearTimeout(collapseTimer);
    }

    if ('IntersectionObserver' in window && anchor) {
      var io = new IntersectionObserver(
        function (entries) {
          if (entries[0].isIntersecting) hide();
          else reveal();
        },
        { rootMargin: '-80px 0px 0px 0px' },
      );
      io.observe(anchor);
    } else {
      reveal();
    }
  })();
</script>
