---
import type { ServiciosData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;
---

<a
  id="floating-cta"
  href={data.contact.whatsappLink}
  target="_blank"
  rel="noopener"
  aria-label="Solicitar recolección por WhatsApp"
  class="group fixed bottom-5 right-5 z-50 flex h-14 w-14 sm:h-auto sm:w-auto items-center justify-center rounded-full bg-brand-600 px-0 sm:px-6 sm:py-4 font-semibold text-white shadow-xl shadow-brand-900/25 ring-1 ring-black/5 opacity-0 translate-y-3 pointer-events-none transition-all duration-300 hover:bg-brand-700 hover:scale-105"
>
  <span class="absolute inline-flex h-full w-full rounded-full bg-brand-500 opacity-30 animate-ping"></span>
  <span class="relative inline-flex items-center gap-2">
    <Icon name="message-circle" class="w-7 h-7 sm:w-5 sm:h-5" />
    <span class="hidden sm:inline">Solicitar recolección</span>
  </span>
</a>

<script is:inline>
  (function () {
    var fab = document.getElementById('floating-cta');
    var anchor = document.getElementById('hero-cta') || document.getElementById('top');
    if (!fab || !anchor) return;
    function show(v) {
      fab.classList.toggle('opacity-0', !v);
      fab.classList.toggle('translate-y-3', !v);
      fab.classList.toggle('pointer-events-none', !v);
    }
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entries) {
          show(!entries[0].isIntersecting);
        },
        { rootMargin: '-80px 0px 0px 0px' },
      );
      io.observe(anchor);
    } else {
      show(true);
    }
  })();
</script>
