---
import type { ServiciosData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;
---

<div id="fab-wrap" class="fixed bottom-5 right-5 z-50 opacity-0 pointer-events-none">
  <span class="fab-ping absolute bottom-0 right-0 -z-10 h-14 w-14 rounded-full bg-brand-500 opacity-40 animate-ping"></span>
  <a
    id="floating-cta"
    href={data.contact.whatsappLink}
    target="_blank"
    rel="noopener"
    aria-label="Solicitar recolección por WhatsApp"
    class="relative inline-flex h-14 items-center overflow-hidden rounded-full bg-brand-600 text-white shadow-xl shadow-brand-900/25 ring-1 ring-black/5 hover:bg-brand-700 transition-colors"
  >
    <span class="fab-text font-semibold">Solicitar recolección</span>
    <span class="grid h-14 w-14 shrink-0 place-items-center">
      <Icon name="message-circle" class="w-6 h-6" />
    </span>
  </a>
</div>

<script is:inline>
  (function () {
    var wrap = document.getElementById('fab-wrap');
    var hero = document.getElementById('hero-cta');
    if (!wrap || !hero) return;
    var hideTimer;

    // Delta del centro del flotante (en su estado actual) al centro del botón del hero.
    function deltaToHero() {
      var w = wrap.getBoundingClientRect();
      var h = hero.getBoundingClientRect();
      return { dx: h.left + h.width / 2 - (w.left + w.width / 2), dy: h.top + h.height / 2 - (w.top + w.height / 2) };
    }

    // El botón del hero "se va" y el flotante toma su lugar, viajando a la esquina y colapsándose.
    function reveal() {
      clearTimeout(hideTimer);
      hero.style.opacity = '0';
      hero.style.pointerEvents = 'none';
      // Estado inicial instantáneo: expandido, encima del botón del hero.
      wrap.classList.add('fab-instant', 'fab-open');
      wrap.style.transform = 'none';
      wrap.style.opacity = '1';
      wrap.classList.remove('pointer-events-none');
      wrap.getBoundingClientRect();
      var d = deltaToHero();
      wrap.style.transform = 'translate(' + d.dx + 'px,' + d.dy + 'px)';
      wrap.getBoundingClientRect();
      wrap.classList.remove('fab-instant');
      requestAnimationFrame(function () {
        wrap.style.transform = 'translate(0,0)';
        wrap.classList.remove('fab-open');
      });
    }

    // El flotante vuela de regreso al hero, expandiéndose, y devuelve el control al botón del hero.
    function toHero() {
      clearTimeout(hideTimer);
      // Medir destino con el estado expandido (como llegará), sin animar.
      wrap.classList.add('fab-instant', 'fab-open');
      wrap.style.transform = 'none';
      wrap.getBoundingClientRect();
      var d = deltaToHero();
      // Volver al estado real actual (colapsado en la esquina) antes de animar.
      wrap.classList.remove('fab-open');
      wrap.getBoundingClientRect();
      wrap.classList.remove('fab-instant');
      requestAnimationFrame(function () {
        wrap.style.transform = 'translate(' + d.dx + 'px,' + d.dy + 'px)';
        wrap.classList.add('fab-open');
      });
      hideTimer = setTimeout(function () {
        hero.style.opacity = '';
        hero.style.pointerEvents = '';
        wrap.classList.add('fab-instant');
        wrap.style.opacity = '0';
        wrap.classList.add('pointer-events-none');
        wrap.classList.remove('fab-open');
        wrap.style.transform = 'none';
        wrap.getBoundingClientRect();
        wrap.classList.remove('fab-instant');
      }, 560);
    }

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entries) {
          if (entries[0].isIntersecting) toHero();
          else reveal();
        },
        { rootMargin: '-90px 0px 0px 0px' },
      );
      io.observe(hero);
    }
  })();
</script>
