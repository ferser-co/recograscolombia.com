---
import type { ServiciosData } from './data';

import Icon from '../../components/Icon.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;

// Tonos por pilar (agua, impacto, economía circular, cumplimiento)
const tones = [
  'bg-teal-50 text-teal-600',
  'bg-emerald-50 text-emerald-600',
  'bg-gold-100 text-gold-600',
  'bg-brand-50 text-brand-600',
];
---

<section id="nosotros" class="py-20 sm:py-28 bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
      <div class="reveal">
        <p class="mb-3 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-brand-700">
          <span class="h-px w-8 bg-brand-700"></span>
          {data.about.eyebrow}
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight text-slate-900 mb-6">
          {data.about.title}
        </h2>
        <div class="space-y-5">
          {data.about.paragraphs.map((p) => (
            <p class="text-base sm:text-lg text-slate-600 leading-relaxed">{p}</p>
          ))}
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-5 self-center">
        {data.about.pillars.map((pillar, i) => (
          <div
            class="reveal p-6 bg-white rounded-2xl border border-slate-200"
            style={`transition-delay: ${i * 80}ms;`}
          >
            <div class={`w-10 h-10 rounded-lg flex items-center justify-center mb-4 ${tones[i % tones.length]}`}>
              <Icon name={pillar.icon} class="w-5 h-5" />
            </div>
            <h3 class="text-base font-bold text-slate-900 mb-1.5">{pillar.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
