---
import type { ServiciosData } from '../data/site';

import Icon from './Icon.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;
---

<div id="fab-wrap" class="fixed bottom-5 right-5 z-50 opacity-0 pointer-events-none">
  <span class="fab-ping absolute bottom-0 right-0 -z-10 h-14 w-14 rounded-full bg-brand-500 opacity-40 animate-ping"></span>
  <a
    id="floating-cta"
    href={data.contact.whatsappLink}
    target="_blank"
    rel="noopener"
    aria-label="Solicitar recolección por WhatsApp"
    class="relative inline-flex h-14 items-center overflow-hidden rounded-full bg-brand-600 text-white shadow-xl shadow-brand-900/25 ring-1 ring-black/5 hover:bg-brand-700 transition-colors"
  >
    <span class="fab-text font-semibold">Solicitar recolección</span>
    <span class="grid h-14 w-14 shrink-0 place-items-center">
      <Icon name="message-circle" class="w-6 h-6" />
    </span>
  </a>
</div>

<script is:inline>
  (function () {
    var wrap = document.getElementById('fab-wrap');
    var hero = document.getElementById('hero-cta');
    if (!wrap || !hero) return;

    var DURATION = 600;            // igual que la transición de transform original (0.6s)
    var rafId = 0;
    var hideTimer = 0;
    var visible = null;            // estado previo de intersección (evita animar al cargar)

    // cubic-bezier(0.5, 0, 0.2, 1) — mismo "feel" que el CSS original
    var ease = (function () {
      var p1x = 0.5, p1y = 0, p2x = 0.2, p2y = 1;
      function A(a, b) { return 1 - 3 * b + 3 * a; }
      function B(a, b) { return 3 * b - 6 * a; }
      function C(a) { return 3 * a; }
      function calc(t, a, b) { return ((A(a, b) * t + B(a, b)) * t + C(a)) * t; }
      function slope(t, a, b) { return 3 * A(a, b) * t * t + 2 * B(a, b) * t + C(a); }
      return function (x) {
        var t = x;
        for (var i = 0; i < 6; i++) {
          var s = slope(t, p1x, p2x);
          if (s === 0) break;
          t -= (calc(t, p1x, p2x) - x) / s;
        }
        return calc(t, p1y, p2y);
      };
    })();

    function heroCenter() {
      var h = hero.getBoundingClientRect();
      return { x: h.left + h.width / 2, y: h.top + h.height / 2 };
    }

    function stopAnim() {
      if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
    }

    // Anima el transform desde (fromX,fromY) hacia un objetivo que puede MOVERSE.
    // opts.target() se evalúa en cada frame -> sigue al hero aunque el scroll siga.
    function fly(fromX, fromY, target, done) {
      stopAnim();
      // Controlamos el transform a mano: desactivamos su transición CSS.
      wrap.style.transition = 'opacity 0.3s ease';
      var t0 = 0;
      function frame(now) {
        if (!t0) t0 = now;
        var p = Math.min(1, (now - t0) / DURATION);
        var e = ease(p);
        var tgt = target();
        var x = fromX + (tgt.x - fromX) * e;
        var y = fromY + (tgt.y - fromY) * e;
        wrap.style.transform = 'translate(' + x + 'px,' + y + 'px)';
        if (p < 1) {
          rafId = requestAnimationFrame(frame);
        } else {
          rafId = 0;
          if (done) done();
        }
      }
      rafId = requestAnimationFrame(frame);
    }

    // El hero "se va" y el flotante toma su lugar, viajando a la esquina y colapsándose.
    function reveal() {
      clearTimeout(hideTimer);
      stopAnim();
      hero.style.opacity = '0';
      hero.style.pointerEvents = 'none';

      // Estado inicial instantáneo: expandido, encima del hero.
      wrap.classList.add('fab-instant', 'fab-open');
      wrap.style.transform = 'none';
      wrap.style.opacity = '1';
      wrap.classList.remove('pointer-events-none');
      var r = wrap.getBoundingClientRect();
      var baseX = r.left + r.width / 2;
      var baseY = r.top + r.height / 2;
      var hc = heroCenter();
      var startX = hc.x - baseX;
      var startY = hc.y - baseY;
      wrap.style.transform = 'translate(' + startX + 'px,' + startY + 'px)';
      wrap.getBoundingClientRect();
      wrap.classList.remove('fab-instant');

      // Colapsa el texto (suave) y vuela a la esquina (objetivo fijo y estable).
      wrap.classList.remove('fab-open');
      fly(startX, startY, function () { return { x: 0, y: 0 }; }, function () {
        wrap.style.transition = '';
      });
    }

    // El flotante vuela de regreso al hero, expandiéndose, persiguiendo su posición REAL.
    function toHero() {
      clearTimeout(hideTimer);
      stopAnim();

      // Medir el centro (sin transform) del flotante YA EXPANDIDO, que es como llegará.
      wrap.classList.add('fab-instant', 'fab-open');
      wrap.style.transform = 'none';
      var r = wrap.getBoundingClientRect();
      var baseX = r.left + r.width / 2;
      var baseY = r.top + r.height / 2;

      // Volver al estado real (colapsado en la esquina) para arrancar la animación.
      wrap.classList.remove('fab-open');
      wrap.style.transform = 'translate(0px,0px)';
      wrap.getBoundingClientRect();
      wrap.classList.remove('fab-instant');
      wrap.classList.add('fab-open'); // expande el texto de forma suave

      // El objetivo se recalcula cada frame con la posición ACTUAL del hero,
      // así el botón aterriza exacto aunque el scroll siga moviéndose.
      fly(0, 0, function () {
        var hc = heroCenter();
        return { x: hc.x - baseX, y: hc.y - baseY };
      }, function () {
        // Entrega sin saltos: el flotante ya está justo sobre el hero.
        hero.style.opacity = '';
        hero.style.pointerEvents = '';
        wrap.classList.add('fab-instant');
        wrap.style.opacity = '0';
        wrap.classList.add('pointer-events-none');
        wrap.classList.remove('fab-open');
        wrap.style.transform = 'none';
        wrap.getBoundingClientRect();
        wrap.classList.remove('fab-instant');
        wrap.style.transition = '';
      });
    }

    // Coloca el estado final al instante, sin animar (para la carga inicial).
    function setRest(inView) {
      stopAnim();
      clearTimeout(hideTimer);
      wrap.classList.add('fab-instant');
      wrap.classList.remove('fab-open');
      wrap.style.transform = 'none';
      if (inView) {
        hero.style.opacity = '';
        hero.style.pointerEvents = '';
        wrap.style.opacity = '0';
        wrap.classList.add('pointer-events-none');
      } else {
        hero.style.opacity = '0';
        hero.style.pointerEvents = 'none';
        wrap.style.opacity = '1';
        wrap.classList.remove('pointer-events-none');
      }
      wrap.getBoundingClientRect();
      wrap.classList.remove('fab-instant');
    }

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entries) {
          var inView = entries[0].isIntersecting;
          if (inView === visible) return; // ignora reportes redundantes
          if (visible === null) {          // primer reporte: sin animación
            visible = inView;
            setRest(inView);
            return;
          }
          visible = inView;
          if (inView) toHero();
          else reveal();
        },
        { rootMargin: '-90px 0px 0px 0px' },
      );
      io.observe(hero);
    }
  })();
</script>