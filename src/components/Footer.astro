---
import type { ServiciosData } from '../data/site';

import Icon from './Icon.astro';
import Logo from './Logo.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;

const socialIcon: Record<string, string> = {
  linkedin: 'linkedin',
  facebook: 'facebook',
  instagram: 'instagram',
  twitter: 'twitter',
  whatsapp: 'message-circle',
  github: 'github',
};
---

<footer class="bg-slate-950 text-slate-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid sm:grid-cols-3 gap-10">
      <div class="sm:col-span-2 max-w-md">
        <div class="mb-4">
          <Logo tone="light" />
        </div>
        <p class="text-sm leading-relaxed text-slate-400">{data.footer.description}</p>
      </div>

      <div>
        <p class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-4">Escríbenos</p>
        <div class="flex gap-3">
          {data.footer.socials.map((s) => (
            <a
              href={s.url}
              aria-label={s.type}
              class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-slate-800 hover:bg-brand-600 transition-colors"
            >
              <Icon name={socialIcon[s.type] ?? 'link'} class="w-4 h-4" />
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-slate-500">{data.footer.copyright}</p>
      <p class="text-xs text-slate-500">
        Hecho por
        <a href="https://ferser.co" class="text-slate-300 hover:text-white font-semibold transition-colors">Ferser</a>
      </p>
    </div>
  </div>
</footer>
