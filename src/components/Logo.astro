---
interface Props {
  /** 'dark' para fondos claros (logo directo), 'light' para fondos oscuros (placa blanca). */
  tone?: 'dark' | 'light';
  class?: string;
}

const { tone = 'dark', class: className = '' } = Astro.props;
---

{tone === 'light' ? (
  <span class={`inline-flex items-center rounded-lg bg-white px-3 py-2 ${className}`}>
    <img src="/img/logo-recogras.webp" alt="Recogras" width="166" height="34" class="h-[34px] w-auto" decoding="async" />
  </span>
) : (
  <img
    src="/img/logo-recogras.webp"
    alt="Recogras"
    width="196"
    height="40"
    class={`h-9 sm:h-10 w-auto ${className}`}
    decoding="async"
  />
)}
