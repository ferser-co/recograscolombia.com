---
import type { ServiciosData } from '../data/site';

import Icon from './Icon.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;
---

<section class="relative overflow-hidden bg-brand-700 py-16 sm:py-20">
  <div class="absolute top-[-80px] right-[-60px] z-0 w-[360px] h-[360px] rounded-full bg-brand-600/40 blur-3xl"></div>
  <div class="absolute bottom-[-100px] left-[-60px] z-0 w-[320px] h-[320px] rounded-full bg-gold-500/20 blur-3xl"></div>
  <Icon name="recycle" class="absolute z-0 -bottom-6 right-8 w-44 h-44 text-white/5" />

  <div class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center reveal">
    <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-white mb-4">
      {data.cta.title}
    </h2>
    <p class="text-base sm:text-lg text-brand-100 max-w-2xl mx-auto mb-8">
      {data.cta.subtitle}
    </p>
    <a
      href={data.cta.button.href}
      class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-8 py-4 text-base font-bold text-brand-700 shadow-xl hover:bg-brand-50 hover:scale-[1.02] transition-all"
    >
      <Icon name="message-circle" class="w-5 h-5" />
      {data.cta.button.label}
    </a>
  </div>
</section>
