---
import type { ServiciosData } from '../data/site';

import Icon from './Icon.astro';
interface Props {
  data: ServiciosData;
}

const { data } = Astro.props;
const { authorization } = data;
---

<section id="autorizacion" class="pt-4 pb-16 sm:pb-20 bg-brand-50/40">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="grid lg:grid-cols-[260px_1fr_auto] items-stretch">
        <!-- Columna del logo -->
        <div class="flex flex-col items-center justify-center gap-4 bg-brand-50/70 px-8 py-10 lg:border-r border-b lg:border-b-0 border-slate-200">
          <img
            src="/img/logo-epa.svg"
            alt="Logo del Establecimiento Público Ambiental (EPA-Cartagena), organismo emisor del certificado"
            class="w-44 h-auto sm:w-48"
            width="192"
            height="192"
          />
          <span class="rounded-full bg-white px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-brand-700 ring-1 ring-brand-100">
            Autoridad ambiental
          </span>
        </div>

        <!-- Contenido -->
        <div class="min-w-0 px-7 py-8 sm:px-9 sm:py-10">
          <p class="mb-2 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-brand-700">
            <span class="h-px w-8 bg-brand-700"></span>
            {authorization.eyebrow}
          </p>
          <h2 class="text-xl sm:text-2xl lg:text-3xl font-black tracking-tight text-slate-900 mb-3">
            {authorization.title}
          </h2>
          <p class="text-sm sm:text-base text-slate-600 leading-relaxed mb-5 max-w-3xl">
            {authorization.text}
          </p>
          <ul class="flex flex-wrap gap-2">
            {authorization.facts.map((fact) => (
              <li class="inline-flex items-center gap-1.5 rounded-lg bg-brand-50 px-3 py-1.5 text-xs font-semibold text-brand-800">
                <Icon name="check" class="w-3.5 h-3.5" />
                {fact}
              </li>
            ))}
          </ul>
        </div>

        <!-- Acciones -->
        <div class="flex flex-col justify-center gap-3 shrink-0 px-7 py-8 sm:px-9 lg:w-64 lg:border-l border-t lg:border-t-0 border-slate-100">
          <a
            href={authorization.pdfUrl}
            download
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition-colors"
          >
            <Icon name="download" class="w-4 h-4" />
            {authorization.pdfLabel}
          </a>
          <a
            href={authorization.verifyUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 hover:border-brand-300 hover:bg-brand-50 transition-colors"
          >
            <Icon name="external-link" class="w-4 h-4" />
            {authorization.verifyLabel}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>